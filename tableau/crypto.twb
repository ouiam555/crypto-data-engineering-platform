      <aliases enabled='yes' />
      <column caption='Crypto Id (Dim Crypto)' datatype='string' name='[CRYPTO_ID (DIM_CRYPTO)]' role='dimension' type='nominal' />
      <column caption='Crypto Id' datatype='string' name='[CRYPTO_ID]' role='dimension' type='nominal' />
      <column caption='Current Price' datatype='real' name='[CURRENT_PRICE]' role='measure' type='quantitative' />
      <column caption='Ratio Volume/MarketCap' datatype='real' name='[Calculation_0578357345718272]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TOTAL_VOLUME]) / SUM([MARKET_CAP])' />
      </column>
      <column caption='Performance Relative' datatype='real' name='[Calculation_0578357347168258]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Price Change Percentag...])' />
      </column>
      <column caption='Variation 7 jours' datatype='real' name='[Calculation_0578357347504131]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([CURRENT_PRICE]) - LOOKUP(AVG([CURRENT_PRICE]), -7)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Date Id (Dim Date)' datatype='integer' name='[DATE_ID (DIM_DATE)]' role='dimension' type='ordinal' />
      <column caption='Date Id' datatype='integer' name='[DATE_ID]' role='dimension' type='ordinal' />
